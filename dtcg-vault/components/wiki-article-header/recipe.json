{
  "$schema": "https://design.pointsav.com/schemas/component-recipe-v1.json",
  "name": "wiki-article-header",
  "display_name": "Wiki Article Header",
  "description": "Top-of-article surface: slug breadcrumb, H1 title (from frontmatter), quality badge, and byline (last edited + editor + history link). Maps Wikipedia article-header muscle-memory using IBM Plex Sans at 2.25rem h1.",
  "category": "wiki",
  "registry_type": "component",
  "status": "stub",
  "stub_source": "component-wiki-article-header-2026-05-06.draft.md — project-editorial brief 2026-05-06T18:30Z",
  "html": "<header class=\"ps-wiki-article-header\">\n  <nav class=\"ps-wiki-article-header__breadcrumb\" aria-label=\"Article location\">\n    <ol class=\"ps-wiki-article-header__crumb-list\">\n      <li><a href=\"{{category-url}}\">{{category-name}}</a></li>\n    </ol>\n  </nav>\n  <div class=\"ps-wiki-article-header__title-row\">\n    <h1 class=\"ps-wiki-article-header__title\">{{title}}</h1>\n    <span class=\"ps-wiki-badge ps-wiki-badge--{{quality-grade}}\" aria-label=\"Article quality: {{quality-grade-label}}\">{{quality-grade-label}}</span>\n  </div>\n  <div class=\"ps-wiki-article-header__meta\" role=\"doc-subtitle\">\n    <span class=\"ps-wiki-article-header__date\">Last edited <time datetime=\"{{iso-date}}\">{{display-date}}</time></span>\n    <span class=\"ps-wiki-article-header__divider\" aria-hidden=\"true\">·</span>\n    <span class=\"ps-wiki-article-header__editor\">{{editor-display-name}}</span>\n    <span class=\"ps-wiki-article-header__divider\" aria-hidden=\"true\">·</span>\n    <a class=\"ps-wiki-article-header__history\" href=\"{{history-url}}\">View history</a>\n  </div>\n</header>",
  "css_class": "ps-wiki-article-header",
  "variants": [
    { "name": "standard", "description": "Breadcrumb + title row (H1 + badge) + byline." },
    { "name": "with-lead-image", "description": "Standard + right-floated <figure>." },
    { "name": "with-infobox", "description": "Standard + right-floated <aside class=\"ps-wiki-infobox\">." },
    { "name": "ungraded", "description": "Badge omitted; title row is H1 only." }
  ],
  "tokens": [
    "{wiki.font-body}",
    "{wiki.text-h1}",
    "{semantic.ink-primary}",
    "{semantic.ink-secondary}",
    "{wiki.link}",
    "{semantic.border-subtle}",
    "{primitive.space-3}",
    "{primitive.space-5}",
    "{primitive.space-7}"
  ],
  "aria": "Breadcrumb <nav aria-label='Article location'> with <ol>. Quality badge <span aria-label='Article quality: {{grade-label}}'>. aria-current='page' on last breadcrumb item. <time datetime> for machine-readable date.",
  "wcag": { "target": "2.2 AA" },
  "open_questions": [],
  "research_links": [],
  "registry_dependencies": ["wiki-badge-tag"]
}
