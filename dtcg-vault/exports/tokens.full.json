  "theme": {
    "$description": "PointSav brand semantic-layer override — maps semantic roles (interactive-primary, surface-elevated, ink-primary) to primitive references. SMB customers fork this file as themes/<their-brand>.json and re-point the references at their own primitive values.",
    "$schema": "https://schemas.designtokens.org/2025-10-01/draft.json",
    "accessibility": {
      "contrast_floor_focus_ring_to_surface": 3,
      "contrast_floor_text_to_surface": 7,
      "min_touch_target_px": 44,
      "motion_respect": "prefers-reduced-motion honored at all interaction layers",
      "wcag_target": "2.2 AAA"
    },
    "github": {
      "edit_path_prefix": "edit/main/dtcg-vault",
      "repo": "https://github.com/pointsav/pointsav-design-system"
    },
    "semantic": {
